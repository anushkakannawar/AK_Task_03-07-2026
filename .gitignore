client/build/
server/dist/

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor files ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Kiro IDE internal files ──────────────────────────────────
.kiro/

